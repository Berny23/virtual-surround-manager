<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APPLICATION_ID@</id>
  <name>Virtual Surround</name>
  <summary>3D sound for headphones</summary>
  
  <url type="homepage">https://github.com/Berny23/virtual-surround-manager</url>
  <url type="vcs-browser">https://github.com/Berny23/virtual-surround-manager</url>
  <url type="bugtracker">https://github.com/Berny23/virtual-surround-manager/issues</url>
  <url type="donation">https://www.buymeacoffee.com/Berny23</url>
  <developer id="de.berny23">
    <name translate="no">Berny23</name>
  </developer>

  <keywords>
    <keyword translate="no">Kirigami</keyword>
    <keyword translate="no">PipeWire</keyword>
    <keyword translate="no">HRIR</keyword>
    <keyword translate="no">HRTF</keyword>
    <keyword translate="no">HeSuVi</keyword>
  </keywords>
  
  <metadata_license>MIT</metadata_license>
  <project_license>MIT</project_license>
  
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
    <control>touch</control>
  </supports>
  
  <content_rating type="oars-1.1" />

  <launchable type="desktop-id">@APPLICATION_ID@.desktop</launchable>

  <branding>
    <color type="primary" scheme_preference="light">#988dfa</color>
    <color type="primary" scheme_preference="dark">#433990</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <caption>Main window</caption>
      <image>https://raw.githubusercontent.com/Berny23/virtual-surround-manager/refs/tags/v1.1.3/dist/flatpak/screenshots/main-window.webp</image>
    </screenshot>
    <screenshot>
      <caption>Main window (dark mode)</caption>
      <image>https://raw.githubusercontent.com/Berny23/virtual-surround-manager/refs/tags/v1.1.3/dist/flatpak/screenshots/main-window-dark.webp</image>
    </screenshot>
    <screenshot>
      <caption>Settings page</caption>
      <image>https://raw.githubusercontent.com/Berny23/virtual-surround-manager/refs/tags/v1.1.3/dist/flatpak/screenshots/settings-page.webp</image>
    </screenshot>
    <screenshot>
      <caption>About page</caption>
      <image>https://raw.githubusercontent.com/Berny23/virtual-surround-manager/refs/tags/v1.1.3/dist/flatpak/screenshots/about-page.webp</image>
    </screenshot>
  </screenshots>

  <description>
    <p>Just open the settings of your favorite game or media player and select real 7.1 or 5.1 audio output. Do not use any additional in-game virtualization setting (like a “headphone” or "3D audio" profile).</p>
    <p>Features:</p>
    <ul>
      <li>Enable/Disable seemlessly, <em>without</em> changing your default device, writing config files or restarting the audio service</li>
      <li>Drop in your own <em>HRIR WAV files</em> as virtualization presets, same as <em>HeSuVi</em> on Windows</li>
      <li>Run it in the background with a <em>system tray icon</em> (enable it in the app's settings)</li>
      <li>Compatible with <em>EasyEffects</em> and most similar apps</li>
    </ul>
    <p>Please note: This app requires the PipeWire audio system. Recent Linux distributions use this by default, so don't worry about it.</p>
  </description>

  <releases>
    <release version="1.1.3" date="2026-07-04">
      <description>
        <ul>
          <li>Disabled tray icon by default, because some desktop environments don't support these out of the box (you can enable it in the app's settings)</li>
          <li>Fixed PipeWire being unable to read WAV files</li>
          <li>Added Italian translation</li>
          <li>Added some web links, screenshots, brand colors, keywords and a better app description</li>
        </ul>
      </description>
    </release>
    <release version="1.1.2" date="2026-07-02">
      <description>
        <ul>
          <li>Fixed the permissions for PipeWire when running in a Flatpak, making this the very first Flatpak release</li>
          <li>Fixed system tray icon for Flatpak</li>
          <li>Added autostart feature for Flatpak</li>
        </ul>
      </description>
    </release>
    <release version="1.1.1" date="2026-06-20">
      <description>
        <ul>
          <li>Fixed autostart and system tray icon on systems where the default directories are missing</li>
          <li>Added Russian translation</li>
        </ul>
      </description>
    </release>
    <release version="1.1.0" date="2026-06-12">
      <description>
        <ul>
          <li>System tray icon, so you can keep the app in the background</li>
          <li>Setting for auto-enabling virtual surround sound on app startup</li>
          <li>Setting for autostarting the app</li>
          <li>Setting for showing or hiding the tray icon</li>
        </ul>
      </description>
    </release>
    <release version="1.0.0" date="2026-04-24">
      <description>
        <p>Initial release of the app.</p>
      </description>
    </release>
  </releases>
</component>