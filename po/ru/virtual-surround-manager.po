msgctxt "@label:switch"
msgid "Automatically start application on login"
msgstr "Автоматически запускать приложение при входе"

msgctxt "@label:switch"
msgid "Automatically enable virtual surround sound"
msgstr "Автоматически включать виртуальный объёмный звук"

msgctxt "@label:combobox"
msgid "Application behavior"
msgstr "Режим приложения"

msgctxt "@info:description"
msgid "How the application should start and run.<br>Restart the program to apply."
msgstr "Как приложение должно запускаться и работать.<br>Перезапустите программу, чтобы применить изменения."

msgctxt "@option"
msgid "Show system tray icon"
