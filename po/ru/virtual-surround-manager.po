msgid "Show system tray icon & hide window on startup"
msgstr "Показать значок в системном лотке и скрыть окно при запуске"

msgctxt "@option"
msgid "Hide system tray icon"
msgstr "Убрать значок из системного лотка"

msgctxt "@label:combobox"
